rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
             request.auth.token.email != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower()));
    }

    function acceptedCommunityTerms() {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.communityTermsVersion == '2026-07-13';
    }

    // Sayaç alanı en fazla ±1 değişebilir (beğeni/yorum toggle'ı).
    // İstemcinin likeCount'u keyfi bir değere (örn. 999999) yazmasını engeller.
    function isCounterNudge(field) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([field]) ||
             (request.resource.data[field] is int &&
              resource.data[field] is int &&
              request.resource.data[field] >= resource.data[field] - 1 &&
              request.resource.data[field] <= resource.data[field] + 1);
    }

    // ── Tarifler ────────────────────────────────────────────────────────────────
    match /recipes/{recipeId} {
      allow read: if true;
      allow create: if isAdmin() ||
                       (acceptedCommunityTerms() &&
                        request.resource.data.authorId == request.auth.uid &&
                        request.resource.data.isOfficial == false);
      allow update: if isSignedIn() &&
                       (isAdmin() ||
                        request.auth.uid == resource.data.authorId ||
                        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount', 'commentCount']) &&
                         isCounterNudge('likeCount') &&
                         isCounterNudge('commentCount')));
      allow delete: if isAdmin();

      // Beğeniler — kullanıcı sadece kendi beğeni dokümanını okur/yazar (belge yolu ile)
      match /likes/{userId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      // Yorumlar — herkes okur, giriş yapan yazar
      match /comments/{commentId} {
        allow read: if true;
        allow create: if acceptedCommunityTerms() &&
                         request.resource.data.userId == request.auth.uid &&
                         request.resource.data.recipeId == recipeId;
        allow update, delete: if isSignedIn() &&
                                  (isAdmin() || request.auth.uid == resource.data.userId);
      }
    }

    // ── Beğeni collectionGroup sorgusu ───────────────────────────────────────────
    // userLikedIdsStream tüm 'likes' alt koleksiyonlarını tek sorguda tarar.
    // Kullanıcı yalnızca userId alanı kendi uid'i olan beğenileri listeleyebilir.
    match /{path=**}/likes/{likeId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ── Malzemeler ───────────────────────────────────────────────────────────────
    match /ingredients/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Meta (seed kontrolü) — sadece admin yazabilir ────────────────────────────
    // Not: Bu belge açık yazılabilir olursa herhangi bir kullanıcı seed
    // sürümünü bozup bir sonraki admin açılışında TÜM recipes koleksiyonunun
    // silinip yeniden tohumlanmasını tetikleyebilir.
    match /_meta/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Kullanıcı profilleri ─────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Engelleme listesi yalnızca hesap sahibi tarafından yönetilir.
      match /blockedUsers/{blockedUserId} {
        allow read, create, delete: if isSignedIn() && request.auth.uid == userId;
        allow update: if false;
      }

      // Uygulama içi bildirimler — SADECE Cloud Functions (Admin SDK) oluşturur.
      // Sahibi okur/siler; güncelleme yalnız 'read' bayrağıyla sınırlı, böylece
      // istemci başlık/gövde/type alanlarını değiştiremez.
      match /notifications/{notifId} {
        allow read, delete: if isSignedIn() && request.auth.uid == userId;
        allow update: if isSignedIn() && request.auth.uid == userId &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']) &&
                         request.resource.data.read is bool;
        allow create: if false;
      }
    }

    // Kullanıcı raporlarını yalnız raporlayan kişi oluşturabilir; raporları
    // inceleme ve durum güncelleme yetkisi yalnız yöneticidedir.
    match /reports/{reportId} {
      allow create: if isSignedIn() &&
                       request.resource.data.reporterId == request.auth.uid &&
                       request.resource.data.keys().hasOnly([
                         'reporterId', 'targetType', 'targetId', 'targetUserId',
                         'reason', 'recipeId', 'status', 'createdAt'
                       ]) &&
                       request.resource.data.targetType in ['comment', 'recipe', 'user'] &&
                       request.resource.data.targetId is string &&
                       request.resource.data.targetUserId is string &&
                       request.resource.data.reason is string &&
                       request.resource.data.reason.size() > 0 &&
                       request.resource.data.reason.size() <= 500 &&
                       request.resource.data.status == 'open';
      allow read, update, delete: if isAdmin();
    }

    // ── Bekleyen tarifler ────────────────────────────────────────────────────────
    // Giriş yapan kullanıcı kendi başvurusunu oluşturabilir ve okuyabilir.
    // Admin tüm bekleyenleri okuyabilir ve status güncelleyebilir.
    match /pending_recipes/{docId} {
      allow read: if isSignedIn() &&
                     (request.auth.uid == resource.data.authorId || isAdmin());
      allow create: if acceptedCommunityTerms() &&
                       request.resource.data.authorId == request.auth.uid &&
                       !request.auth.token.firebase.sign_in_provider.matches('anonymous');
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Admin koleksiyonu ────────────────────────────────────────────────────────
    // Giriş yapan herkes okuyabilir (kendi admin durumunu kontrol etmek için).
    // İlk admin seed'i: SADECE kurucunun e-postası için, o belge henüz yoksa,
    // giriş yapan herhangi bir kullanıcı yazabilir (bootstrap). Başka hiçbir
    // e-posta için bu istisna geçerli değil — yoksa herkes kendini admin yapabilir.
    match /admins/{email} {
      // get: herkes kendi admin durumunu tek belgeyle kontrol edebilir.
      // list: e-posta adreslerinin toplu sızmasını önlemek için sadece admin.
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update: if isAdmin() ||
                      (isSignedIn() &&
                       email == 'ogulcandnsvr@gmail.com' &&
                       !exists(/databases/$(database)/documents/admins/$(email)));
      // Kurucunun admin belgesi hiçbir admin tarafından (kendisi dahil) silinemez —
      // hesap kurtarma yolu olmadan yanlışlıkla ya da kötü niyetle kilitlenmeyi önler.
      allow delete: if isAdmin() && email != 'ogulcandnsvr@gmail.com';
    }
  }
}
