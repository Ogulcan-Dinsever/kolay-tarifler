rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Tarif görselleri — herkes okur, admin yazar
    match /recipes/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email != null;
    }

    // Bekleyen tarif görselleri — kullanıcı kendi klasörüne yazar
    match /pending_recipes/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Profil fotoğrafları — kullanıcı kendi klasörüne yazar
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
