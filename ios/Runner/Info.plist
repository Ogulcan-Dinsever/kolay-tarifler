	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>fetch</string>
	</array>
	<!-- Push token'ının sistem tarafından otomatik kaydı; FirebaseMessaging
	     yönetir -->
	<key>FirebaseAppDelegateProxyEnabled</key>
	<true/>
</dict>
</plist>
