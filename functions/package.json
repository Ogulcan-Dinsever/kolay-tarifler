{
  "name": "kolay-tarifler-functions",
  "description": "Cloud Functions for Kolay Tarifler",
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "scripts": {
    "test": "node --test notification_helpers.test.js",
    "test:rules": "firebase emulators:exec --only firestore \"node --test --test-concurrency=1 firestore_rules.test.js counter_helpers.test.js\" --project demo-kolay-tarifler",
    "deploy": "firebase deploy --only functions --project kolaytarifler-37c45",
    "logs": "firebase functions:log --project kolaytarifler-37c45"
  },
  "dependencies": {
    "firebase-admin": "^14.2.0",
    "firebase-functions": "^7.3.0"
  },
  "private": true,
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "firebase": "^12.16.0",
    "firebase-tools": "^15.24.0"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
